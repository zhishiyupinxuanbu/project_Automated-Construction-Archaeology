    },
    {
      "index": 20,
      "text": "",
      "style": "Body Text",
      "alignment": "inherit",
      "first_line_indent_pt": 0.0,
      "left_indent_pt": 0.0,
      "right_indent_pt": 0.0,
      "space_before_pt": null,
      "space_after_pt": null,
      "line_spacing": "355600",
      "fonts": [],
      "has_bold": false,
      "has_highlight": false
    },
    {
      "index": 21,
      "text": "",
      "style": "Body Text",
      "alignment": "inherit",
      "first_line_indent_pt": 0.0,
      "left_indent_pt": 0.0,
