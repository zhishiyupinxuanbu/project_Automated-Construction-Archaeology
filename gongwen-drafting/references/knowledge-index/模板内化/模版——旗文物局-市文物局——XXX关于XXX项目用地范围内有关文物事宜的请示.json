      "index": 1,
      "text": "乌审旗文物局关于滴哨沟湾至三岔沟湾通村公路项目用地范围内有关文物事宜的请示",
      "style": "Normal",
      "alignment": "center",
      "first_line_indent_pt": null,
      "left_indent_pt": null,
      "right_indent_pt": null,
      "space_before_pt": null,
      "space_after_pt": null,
      "line_spacing": null,
      "fonts": [],
      "has_bold": false,
      "has_highlight": false
    },
    {
      "index": 2,
      "text": "",
      "style": "Normal",
      "alignment": "justify",
      "first_line_indent_pt": null,
      "left_indent_pt": null,
      "right_indent_pt": null,
      "space_before_pt": null,
